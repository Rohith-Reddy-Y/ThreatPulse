# ============================================
# ThreatPulse — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# In production (NODE_ENV=production), JWT_SECRET is REQUIRED — the server
# will refuse to start without it.

# Environment: "development" or "production"
NODE_ENV=development

# Server
PORT=3000

# ── Security (REQUIRED in production) ──────────────────
# Stable secret used to sign session tokens. Must be >= 32 chars.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Domain name for automatic HTTPS (Caddy). Use a free DuckDNS subdomain if you don't
# own a domain, e.g. myapp.duckdns.org  (leave blank for HTTP-only on the raw IP).
DOMAIN=

# Public base URL of the app (used for password-reset links). e.g. https://myapp.duckdns.org
BASE_URL=

# Restrict browser CORS to this origin in production (defaults to "*" if unset).
ALLOWED_ORIGIN=*

# Optional: set the initial admin password instead of an auto-generated one.
# The admin is still forced to change it on first login.
ADMIN_INITIAL_PASSWORD=

# Optional: admin email (enables the admin's forgot-password flow out of the box).
# Can also be set later from the dashboard account menu.
ADMIN_EMAIL=

# Optional: override the SQLite database file path.
# DB_PATH=/data/threatpulse.db

# ── NVD API Key ────────────────────────────────────────
# Get a free key at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# ── abuse.ch API Key ───────────────────────────────────
# Required for ThreatFox / URLhaus / MalwareBazaar (they now mandate auth).
# Get a free key at https://auth.abuse.ch
ABUSE_CH_API_KEY=

# ── Email Notifications (Gmail SMTP example) ───────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
NOTIFICATION_EMAIL=recipient@example.com

# ── Telegram Bot Notifications ─────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Microsoft Teams (optional global fallback) ─────────
# Channel → Connectors/Workflows → Incoming Webhook. Users can also set this per-account in the UI.
TEAMS_WEBHOOK=

# ── WhatsApp via CallMeBot (optional global fallback) ──
# Message +34 644 51 95 23 on WhatsApp with "I allow callmebot to send me messages" to get a key.
WHATSAPP_NUMBER=
WHATSAPP_APIKEY=

# ── Feed Fetch Interval (cron expression — default: every 15 minutes) ──
FETCH_CRON=*/15 * * * *

# Dashboard Auto-Refresh Interval (seconds)
DASHBOARD_REFRESH=60
